<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Catava Air — Dynamisch Torensimulator v3</title>
<style>
:root {
  --green:      #1D9E75;
  --green-dk:   #085041;
  --green-lt:   #E1F5EE;
  --green-pal:  #f0faf5;
  --amber:      #BA7517;
  --amber-lt:   #FAEEDA;
  --blue:       #185FA5;
  --blue-lt:    #E6F1FB;
  --red:        #A32D2D;
  --red-lt:     #FCEBEB;
  --gray-900:   #1a1a18;
  --gray-700:   #3a3a37;
  --gray-500:   #6b6b67;
  --gray-300:   #d0cec4;
  --gray-100:   #f2f0ea;
  --white:      #ffffff;
  --r:          8px;
  --r-lg:       13px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',system-ui,sans-serif;background:var(--gray-100);color:var(--gray-900);font-size:14px;line-height:1.5}

/* HEADER */
header{background:var(--gray-900);border-bottom:2px solid var(--green);position:sticky;top:0;z-index:200}
.hdr{max-width:1400px;margin:0 auto;padding:.6rem 1.25rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap}
.logo{display:flex;align-items:center;gap:.6rem}
.logo-name{color:#fff;font-size:.95rem;font-weight:700;letter-spacing:.02em}
.logo-sub{color:var(--green);font-size:.65rem;text-transform:uppercase;letter-spacing:.07em}
nav{display:flex;gap:3px;flex-wrap:wrap}
.nb{padding:4px 12px;border:1px solid rgba(255,255,255,.15);border-radius:20px;font-size:.75rem;cursor:pointer;background:transparent;color:rgba(255,255,255,.55);transition:all .15s}
.nb:hover{background:rgba(255,255,255,.08);color:#fff}
.nb.act{background:var(--green);border-color:var(--green);color:#fff}

/* LAYOUT */
main{max-width:1400px;margin:0 auto;padding:1.25rem}
.tp{display:none}.tp.act{display:block}
.grid2{display:grid;grid-template-columns:340px 1fr;gap:1.1rem;align-items:start}
@media(max-width:900px){.grid2{grid-template-columns:1fr}}
.grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:.75rem}
.grid4{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:.65rem;margin-top:.5rem}
.col{display:flex;flex-direction:column;gap:.9rem}

/* CARDS */
.card{background:var(--white);border:1px solid var(--gray-300);border-radius:var(--r-lg);padding:1rem 1.1rem;box-shadow:0 1px 4px rgba(0,0,0,.06)}
.card h2{font-size:.73rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--gray-500);margin-bottom:.75rem;display:flex;align-items:center;gap:.4rem}

/* METRIC CARDS */
.mc{background:var(--gray-100);border:1px solid var(--gray-300);border-radius:var(--r);padding:.65rem .8rem}
.mc.hi{background:var(--blue-lt);border-color:#b5d4f4}
.mc.ok{background:var(--green-lt);border-color:#9FE1CB}
.mc.wn{background:var(--amber-lt);border-color:#FAC775}
.mc.er{background:var(--red-lt);border-color:#f7c1c1}
.mc-lbl{font-size:.68rem;color:var(--gray-500);margin-bottom:2px}
.mc-val{font-size:1.15rem;font-weight:700;color:var(--gray-900)}
.mc-uni{font-size:.65rem;color:var(--gray-500);margin-top:1px}
.mc.hi .mc-lbl,.mc.hi .mc-val,.mc.hi .mc-uni{color:var(--blue)}
.mc.ok .mc-lbl,.mc.ok .mc-val,.mc.ok .mc-uni{color:var(--green-dk)}
.mc.wn .mc-lbl,.mc.wn .mc-val,.mc.wn .mc-uni{color:var(--amber)}
.mc.er .mc-lbl,.mc.er .mc-val,.mc.er .mc-uni{color:var(--red)}

/* SECTION TITLE */
.stitle{font-size:.73rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--gray-500);margin-bottom:.6rem}

/* SLIDERS */
.sg{display:flex;flex-direction:column;gap:.55rem}
.sr{display:flex;align-items:center;gap:7px}
.sr label{font-size:.75rem;color:var(--gray-700);min-width:170px;flex-shrink:0}
.sr input[type=range]{flex:1;height:4px;accent-color:var(--green);cursor:pointer}
.sv{font-size:.75rem;font-weight:700;color:var(--gray-900);min-width:68px;text-align:right;font-variant-numeric:tabular-nums}

/* NUMBER INPUTS */
.ni-group{display:grid;grid-template-columns:repeat(auto-fit,minmax(100px,1fr));gap:.5rem}
.ni-wrap{display:flex;flex-direction:column;gap:3px}
.ni-wrap label{font-size:.68rem;color:var(--gray-500)}
.ni-wrap input[type=number]{width:100%;padding:5px 8px;border:1px solid var(--gray-300);border-radius:var(--r);font-size:.82rem;font-weight:600;color:var(--gray-900);background:var(--white)}
.ni-wrap input:focus{outline:2px solid var(--green);border-color:var(--green)}
.ni-unit{font-size:.65rem;color:var(--gray-500);text-align:right}

/* BADGES */
.badge{font-size:.62rem;padding:2px 7px;border-radius:20px;font-weight:600}
.b-green{background:var(--green-lt);color:var(--green-dk)}
.b-amber{background:var(--amber-lt);color:var(--amber)}

/* FORMULA BOX */
.fbox{background:var(--gray-900);border-radius:var(--r);padding:.75rem 1rem;font-family:'Courier New',monospace;font-size:.75rem;color:rgba(255,255,255,.6);margin-top:.6rem;line-height:1.9}
.fbox .fv{color:var(--green);font-weight:700}

/* DIVIDER */
hr{border:none;border-top:1px solid var(--gray-100);margin:.85rem 0}

/* VD TABLE */
.vdt{width:100%;border-collapse:collapse;font-size:.72rem}
.vdt th{background:var(--gray-900);color:rgba(255,255,255,.6);padding:5px 7px;font-weight:500;text-align:center}
.vdt td{padding:5px 6px;text-align:center;font-weight:600;border:1px solid rgba(255,255,255,.5);border-radius:3px}
.vd-ok{background:#e1f5ee;color:#085041}
.vd-gd{background:#c0dd97;color:#27500a}
.vd-wn{background:#faeeda;color:#854f0b}
.vd-bd{background:#fac775;color:#633806}
.vd-xx{background:#f7c1c1;color:#791f1f}

/* CANVAS WRAP */
.cw{background:var(--white);border:1px solid var(--gray-300);border-radius:var(--r-lg);padding:.75rem;display:flex;justify-content:center;overflow:hidden}
canvas{display:block}

/* LEVEL CARDS */
.lc{background:var(--white);border:1px solid var(--gray-300);border-radius:var(--r);padding:.65rem .9rem;display:grid;grid-template-columns:1fr auto;align-items:center;gap:.5rem}
.lc.lca{border-color:var(--green);background:var(--green-lt)}
.lc-name{font-size:.78rem;font-weight:700}
.lc-det{font-size:.68rem;color:var(--gray-500)}
.lbdg{font-size:.7rem;font-weight:700;padding:3px 9px;border-radius:20px;background:var(--gray-900);color:#fff;white-space:nowrap}
.lc.lca .lbdg{background:var(--green)}

/* FOOTER */
footer{border-top:1px solid var(--gray-300);background:var(--white);margin-top:1.5rem}
.ftr{max-width:1400px;margin:0 auto;padding:.6rem 1.25rem;display:flex;justify-content:space-between;font-size:.68rem;color:var(--gray-500);flex-wrap:wrap;gap:.3rem}

/* PROSE */
.prose{font-size:.78rem;color:var(--gray-700);line-height:1.75}
.prose strong{color:var(--gray-900)}

/* TWO-TOWER SPACING CONTROL */
.spacing-ctrl{display:flex;align-items:center;gap:10px;margin-bottom:.75rem}
.spacing-ctrl label{font-size:.78rem;color:var(--gray-700);white-space:nowrap}
.spacing-ctrl input[type=range]{flex:1;accent-color:var(--green)}
.spacing-ctrl .sv{min-width:70px}
</style>
</head>
<body>

<header>
<div class="hdr">
  <div class="logo">
    <svg width="30" height="30" viewBox="0 0 30 30" fill="none" aria-hidden="true">
      <ellipse cx="15" cy="5.5" rx="9" ry="3.5" fill="#1D9E75" opacity=".9"/>
      <path d="M6 5.5 Q9 15 11 25 L19 25 Q21 15 24 5.5" fill="none" stroke="#1D9E75" stroke-width="1.4"/>
      <ellipse cx="15" cy="17" rx="6" ry="2.5" fill="none" stroke="#1D9E75" stroke-width=".9" opacity=".55"/>
      <ellipse cx="15" cy="25" rx="9" ry="3.5" fill="#1D9E75" opacity=".35"/>
    </svg>
    <div>
      <div class="logo-name">Catava Air</div>
      <div class="logo-sub">Dynamisch Torensimulator v3</div>
    </div>
  </div>
  <nav>
    <button class="nb act" data-tab="geometrie">Geometrie</button>
    <button class="nb" data-tab="performance">Performance</button>
    <button class="nb" data-tab="dubbel">2 Torens</button>
    <button class="nb" data-tab="hectare">Per hectare</button>
    <button class="nb" data-tab="nozzles">Nozzles</button>
    <button class="nb" data-tab="vd">VD-matrix</button>
  </nav>
</div>
</header>

<main>

<!-- ══════════════════════════════════════════════
     TAB 1 — GEOMETRIE
══════════════════════════════════════════════ -->
<section id="tab-geometrie" class="tp act">
<div class="grid2">
  <div class="col">
    <div class="card">
      <h2>Torengeometrie — vrij instelbaar</h2>
      <div class="ni-group" id="geom-inputs"></div>
    </div>
    <div class="card">
      <h2>Berekende oppervlakken</h2>
      <div class="grid4" id="r-geom-areas"></div>
    </div>
    <div class="card">
      <h2>Zonehoogtes</h2>
      <p class="prose">Totale toren = Boven-conus + Tussenstuk + Onder-conus. Pas elke zone afzonderlijk aan. De tekening rechts actualiseert direct.</p>
      <div class="fbox" id="geom-formula"></div>
    </div>
  </div>
  <div class="col">
    <div class="stitle">Doorsnede-aanzicht (schaal proportioneel)</div>
    <div class="cw"><canvas id="cvs-tower" width="320" height="500"></canvas></div>
  </div>
</div>
</section>

<!-- ══════════════════════════════════════════════
     TAB 2 — PERFORMANCE
══════════════════════════════════════════════ -->
<section id="tab-performance" class="tp">
<div class="grid2">
  <div class="col">
    <div class="card">
      <h2>Klimaatinvoer</h2>
      <div class="sg" id="sl-klimaat"></div>
    </div>
    <div class="card">
      <h2>Waterinvoer</h2>
      <div class="sg" id="sl-water"></div>
    </div>
  </div>
  <div class="col">
    <div class="stitle">Kernresultaten per toren</div>
    <div class="grid4" id="r-perf-main"></div>
    <div class="fbox" id="r-perf-formula" style="margin-top:.75rem"></div>
    <div class="stitle" style="margin-top:1rem">Venturi-analyse</div>
    <div class="grid4" id="r-venturi"></div>
    <div class="cw" style="margin-top:.75rem"><canvas id="cvs-venturi" width="460" height="240"></canvas></div>
  </div>
</div>
</section>

<!-- ══════════════════════════════════════════════
     TAB 3 — 2 TORENS
══════════════════════════════════════════════ -->
<section id="tab-dubbel" class="tp">
<div class="grid2">
  <div class="col">
    <div class="card">
      <h2>Afstand tussen torens</h2>
      <div class="spacing-ctrl">
        <label>Hart-op-hart afstand</label>
        <input type="range" id="sl-spacing" min="2" max="25" step="0.5" value="10" oninput="onSpacing(this.value)">
        <span class="sv" id="sv-spacing">10,0 m</span>
      </div>
      <div class="card" style="background:var(--gray-100);border-color:var(--gray-300)">
        <div class="grid4" id="r-dubbel-cards"></div>
      </div>
    </div>
    <div class="card">
      <h2>Invloedszones</h2>
      <p class="prose">Elke toren heeft een effectieve invloedsstraal. Bij overlap versterken de zones elkaar. De kleuroverlay toont de gecombineerde VD-reductie.</p>
      <div class="grid4" id="r-dubbel-zone" style="margin-top:.5rem"></div>
    </div>
  </div>
  <div class="col">
    <div class="stitle">Bovenaanzicht — 2 torens met invloedszones</div>
    <div class="cw"><canvas id="cvs-dubbel-top" width="480" height="300"></canvas></div>
    <div class="stitle" style="margin-top:.75rem">Zijaanzicht — schaal proportioneel</div>
    <div class="cw"><canvas id="cvs-dubbel-side" width="480" height="220"></canvas></div>
  </div>
</div>
</section>

<!-- ══════════════════════════════════════════════
     TAB 4 — PER HECTARE
══════════════════════════════════════════════ -->
<section id="tab-hectare" class="tp">
<div class="grid2">
  <div class="col">
    <div class="card">
      <h2>Configuratie per hectare</h2>
      <div class="sg" id="sl-ha"></div>
      <div class="grid4" id="r-ha-main" style="margin-top:.6rem"></div>
    </div>
    <div class="card">
      <h2>Inzetniveaus referentie</h2>
      <div style="display:flex;flex-direction:column;gap:.45rem" id="r-levels"></div>
    </div>
  </div>
  <div class="col">
    <div class="stitle">Rastervisualisatie per hectare</div>
    <div class="cw"><canvas id="cvs-ha" width="460" height="460"></canvas></div>
    <div class="stitle" style="margin-top:.75rem">Waterverbruik vs. torens/ha</div>
    <div class="cw"><canvas id="cvs-ha-line" width="460" height="180"></canvas></div>
  </div>
</div>
</section>

<!-- ══════════════════════════════════════════════
     TAB 5 — NOZZLES
══════════════════════════════════════════════ -->
<section id="tab-nozzles" class="tp">
<div class="grid2">
  <div class="col">
    <div class="card">
      <h2>Nozzle-type selectie</h2>
      <div id="nozzle-sel"></div>
    </div>
    <div class="card">
      <h2>Ringconfiguratie</h2>
      <div class="sg" id="sl-nozzle"></div>
      <div class="grid4" id="r-nozzle-result" style="margin-top:.6rem"></div>
    </div>
    <div class="card">
      <h2>Waterbalans</h2>
      <div class="grid4" id="r-nozzle-balans"></div>
    </div>
  </div>
  <div class="col">
    <div class="stitle">KBN-capaciteit per druk (beide types)</div>
    <div style="overflow-x:auto">
      <table id="nozzle-tbl" style="width:100%;border-collapse:collapse;font-size:.75rem">
        <thead id="nozzle-thead"></thead>
        <tbody id="nozzle-tbody"></tbody>
      </table>
    </div>
  </div>
</div>
</section>

<!-- ══════════════════════════════════════════════
     TAB 6 — VD-MATRIX
══════════════════════════════════════════════ -->
<section id="tab-vd" class="tp">
<div class="grid2">
  <div class="col">
    <div class="card">
      <h2>VD-doelbereik</h2>
      <div class="sg" id="sl-vd"></div>
      <div style="margin-top:.75rem;display:flex;flex-direction:column;gap:5px">
        <div style="display:flex;align-items:center;gap:7px;font-size:.72rem"><span style="width:11px;height:11px;border-radius:3px;background:#e1f5ee;border:1px solid #9FE1CB;display:inline-block"></span>Al goed (VD &lt; min)</div>
        <div style="display:flex;align-items:center;gap:7px;font-size:.72rem"><span style="width:11px;height:11px;border-radius:3px;background:#c0dd97;border:1px solid #639922;display:inline-block"></span>Haalbaar (VD min–max)</div>
        <div style="display:flex;align-items:center;gap:7px;font-size:.72rem"><span style="width:11px;height:11px;border-radius:3px;background:#faeeda;border:1px solid #FAC775;display:inline-block"></span>Grensgebied (8–10)</div>
        <div style="display:flex;align-items:center;gap:7px;font-size:.72rem"><span style="width:11px;height:11px;border-radius:3px;background:#fac775;border:1px solid #EF9F27;display:inline-block"></span>Moeilijk (10–14)</div>
        <div style="display:flex;align-items:center;gap:7px;font-size:.72rem"><span style="width:11px;height:11px;border-radius:3px;background:#f7c1c1;border:1px solid #E24B4A;display:inline-block"></span>Buiten bereik (&gt;14)</div>
      </div>
    </div>
    <div class="card">
      <h2>Uitleg VD</h2>
      <p class="prose">VD = verzadigde absolute vochtigheid − werkelijke absolute vochtigheid (g/m³). Optimaal voor gewas: <strong>VD 2–8 g/m³</strong>. Boven 10 g/m³ sluiten huidmondjes en stopt plantengroei.</p>
    </div>
  </div>
  <div class="col">
    <div class="stitle">VD-matrix: temperatuur × relatieve vochtigheid (g/m³)</div>
    <div style="overflow-x:auto"><table class="vdt" id="vd-matrix"></table></div>
  </div>
</div>
</section>

</main>
<footer><div class="ftr">
  <span>Catava Air BV — Dynamisch Torensimulator v3</span>
  <span id="ft-geom"></span>
  <span id="ft-ts"></span>
</div></footer>

<script>
// ═══════════════════════════════════════════════════════════════
// CONSTANTEN
// ═══════════════════════════════════════════════════════════════
const HVAP=2450, CP=1.006, RHO=1.15;

// ═══════════════════════════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════════════════════════
const G = {
  D_top:1067, D_throat:800, D_mid:800, D_bot:1000,
  H_top:1950, H_mid:1500, H_bot:400,
};
const S = {
  Tin:35, RV:30, dT:10, eta:85, water:48,
  NT:32, NR:8, P1:20, P2:31, nozzle:'80125',
  spacing:10, vdMin:2, vdMax:8,
};

// Computed area (m²)
function A(Dmm){ return Math.PI*(Dmm/2000)**2; }
function totalH(){ return G.H_top+G.H_mid+G.H_bot; }

// ═══════════════════════════════════════════════════════════════
// NOZZLE PHYSICS  q ∝ √P  (ref: 7.5 l/h @ 10bar for 80125)
// ═══════════════════════════════════════════════════════════════
const NOZZLES = {
  '80125':{ lbl:'KBN 80125', qRef:7.5,  desc:'0,125 L/min — koeling' },
  '80063':{ lbl:'KBN 80063', qRef:3.78, desc:'0,063 L/min — VD-sturing' },
};
function nozzleQ(type,bar){ return NOZZLES[type].qRef*Math.sqrt(bar/10); }

// ═══════════════════════════════════════════════════════════════
// CORE COMPUTE
// ═══════════════════════════════════════════════════════════════
function compute(){
  const eta=S.eta/100;
  const Qmax=(S.water/3600)*HVAP;
  const Qnet=Qmax*eta;
  const mAir=Qnet/(CP*S.dT);
  const Vair=mAir/RHO;
  const Vairh=Vair*3600;
  const Tout=S.Tin-S.dT;

  const a1=A(G.D_top), a2=A(G.D_throat), a3=A(G.D_mid), a4=A(G.D_bot);
  const v1=Vair/a1, v2=Vair/a2, v3=Vair/a3, v4=Vair/a4;
  const dP=0.5*RHO*(v2**2-v1**2)/100;
  const H_m=totalH()/1000;
  const avgV=(v1+v2+v3+v4)/4;
  const verblijf=H_m/avgV;

  const vdIn=satH(S.Tin)*(1-S.RV/100);
  const vdOut=satH(Tout)*0.03;
  const moistAdd=(S.water*eta)/(Vairh||1);

  const f1=nozzleQ(S.nozzle,S.P1), f2=nozzleQ(S.nozzle,S.P2);
  const wR1=S.NR*f1, wR2=S.NR*f2, wTot=wR1+wR2;

  const m2=10000/S.NT;
  const radius=Math.sqrt(m2/Math.PI);
  const hoh=Math.sqrt(m2);

  return {eta,Qmax,Qnet,mAir,Vairh,Tout,a1,a2,a3,a4,v1,v2,v3,v4,
          dP,verblijf,vdIn,vdOut,moistAdd,f1,f2,wR1,wR2,wTot,m2,radius,hoh};
}

function satH(T){ return 4.849*Math.exp(0.0653*T); }

// ═══════════════════════════════════════════════════════════════
// HTML HELPERS
// ═══════════════════════════════════════════════════════════════
function mc(lbl,val,unit,cls){
  return `<div class="mc ${cls||''}"><div class="mc-lbl">${lbl}</div><div class="mc-val">${val}</div><div class="mc-uni">${unit}</div></div>`;
}
function r2(v){return Math.round(v*100)/100;}
function r1(v){return Math.round(v*10)/10;}

// ═══════════════════════════════════════════════════════════════
// GEOMETRY INPUTS
// ═══════════════════════════════════════════════════════════════
function buildGeomInputs(){
  const fields=[
    {id:'D_top',  lbl:'Ø boven (binnenmaat)',  unit:'mm'},
    {id:'D_throat',lbl:'Ø venturi-keel',       unit:'mm'},
    {id:'D_mid',  lbl:'Ø tussenstuk',          unit:'mm'},
    {id:'D_bot',  lbl:'Ø onderzijde',          unit:'mm'},
    {id:'H_top',  lbl:'H boven-conus',         unit:'mm'},
    {id:'H_mid',  lbl:'H tussenstuk',          unit:'mm'},
    {id:'H_bot',  lbl:'H onder-uitloop',       unit:'mm'},
  ];
  document.getElementById('geom-inputs').innerHTML=
    fields.map(f=>`
      <div class="ni-wrap">
        <label>${f.lbl}</label>
        <input type="number" id="gi-${f.id}" value="${G[f.id]}" min="100" max="5000" step="10"
               oninput="onGeom('${f.id}',this.value)">
        <span class="ni-unit">${f.unit}</span>
      </div>`).join('');
}

function onGeom(id,val){
  G[id]=+val||G[id];
  renderAll();
}

// ═══════════════════════════════════════════════════════════════
// SLIDERS
// ═══════════════════════════════════════════════════════════════
const SLIDER_DEFS={
  klimaat:[
    {id:'Tin',  lbl:'Buitentemperatuur', min:20,max:45,step:1,  fmt:v=>v+' °C'},
    {id:'RV',   lbl:'Rel. vochtigheid',  min:10,max:90,step:5,  fmt:v=>v+' %'},
    {id:'dT',   lbl:'Doelkoeling ΔT',    min:3, max:15,step:1,  fmt:v=>v+' K'},
    {id:'eta',  lbl:'Verdampingserendement', min:50,max:100,step:5,fmt:v=>v+' %'},
  ],
  water:[
    {id:'water',lbl:'Water per toren',   min:10,max:100,step:2, fmt:v=>v+' l/h'},
  ],
  ha:[
    {id:'NT',   lbl:'Torens per hectare',min:15,max:55,step:1,  fmt:v=>v+' /ha'},
  ],
  nozzle:[
    {id:'NR',   lbl:'Nozzles per ring',  min:4, max:20,step:1,  fmt:v=>v},
    {id:'P1',   lbl:'Druk ring 1',       min:3, max:35,step:1,  fmt:v=>v+' bar'},
    {id:'P2',   lbl:'Druk ring 2',       min:3, max:35,step:1,  fmt:v=>v+' bar'},
  ],
  vd:[
    {id:'vdMin',lbl:'VD-doel minimum',   min:0, max:5, step:1,  fmt:v=>v+' g/m³'},
    {id:'vdMax',lbl:'VD-doel maximum',   min:5, max:14,step:1,  fmt:v=>v+' g/m³'},
  ],
};

function buildSliders(group,containerId){
  const defs=SLIDER_DEFS[group];
  const el=document.getElementById(containerId);
  if(!el) return;
  el.innerHTML=defs.map(d=>`
    <div class="sr">
      <label for="sl-${d.id}">${d.lbl}</label>
      <input type="range" id="sl-${d.id}" min="${d.min}" max="${d.max}" step="${d.step}"
             value="${S[d.id]}" oninput="onSlider('${d.id}',this.value,'${group}')">
      <span class="sv" id="sv-${d.id}">${d.fmt(S[d.id])}</span>
    </div>`).join('');
}

function onSlider(id,val,group){
  S[id]=+val;
  const def=SLIDER_DEFS[group].find(d=>d.id===id);
  const sv=document.getElementById('sv-'+id);
  if(sv&&def) sv.textContent=def.fmt(+val);
  renderAll();
}

function onSpacing(val){
  S.spacing=+val;
  document.getElementById('sv-spacing').textContent=r1(+val)+' m';
  renderDubbel(compute());
}

